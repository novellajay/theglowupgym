---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "../components/BlogCard.astro";
import Button from "../components/Button.astro";

const substackBase = "https://novella.substack.com";

const categoryMeta: Record<string, { color: string; description: string; gradient: string }> = {
  Fitness: {
    color: "#7C5C52",
    description: "Workouts, strength, and movement",
    gradient: "linear-gradient(135deg, #B07870 0%, #7C5C52 100%)",
  },
  Nutrition: {
    color: "#A67C6D",
    description: "Food, fueling, and nourishment",
    gradient: "linear-gradient(135deg, #D4A5A0 0%, #A67C6D 100%)",
  },
  Mindset: {
    color: "#C4A882",
    description: "Habits, motivation, and mental health",
    gradient: "linear-gradient(135deg, #E8D5C4 0%, #C4A882 100%)",
  },
};

const posts = [
  {
    title: "5 Signs Your Hormones Are Affecting Your Weight Loss",
    excerpt:
      "Struggling to lose weight despite doing everything 'right'? Your hormones might be working against you. Here's how to spot the signs — and what to do about them.",
    category: "Nutrition",
    date: "May 18, 2025",
    slug: "hormones-weight-loss",
    substackUrl: `${substackBase}/p/hormones-weight-loss`,
    gradient: "linear-gradient(135deg, #D4A5A0 0%, #A67C6D 100%)",
  },
  {
    title: "The Strength Training Guide for Women Who've Never Lifted",
    excerpt:
      "Intimidated by the weight room? You shouldn't be. This beginner-friendly guide breaks down exactly where to start — no experience required.",
    category: "Fitness",
    date: "May 11, 2025",
    slug: "strength-training-beginners",
    substackUrl: `${substackBase}/p/strength-training-beginners`,
    gradient: "linear-gradient(135deg, #B07870 0%, #7C5C52 100%)",
  },
  {
    title: "What to Eat Before and After Your Workout",
    excerpt:
      "Fueling your training correctly can mean the difference between a great session and running on empty. Here's the simple framework I give every client.",
    category: "Nutrition",
    date: "May 4, 2025",
    slug: "pre-post-workout-nutrition",
    substackUrl: `${substackBase}/p/pre-post-workout-nutrition`,
    gradient: "linear-gradient(135deg, #C4A882 0%, #A67C6D 100%)",
  },
  {
    title: "How I Help My Clients Ditch the 'All or Nothing' Mindset",
    excerpt:
      "One missed workout shouldn't spiral into a lost week. Here's the mindset shift that's helped hundreds of my clients stay consistent — without being perfect.",
    category: "Mindset",
    date: "April 27, 2025",
    slug: "all-or-nothing-mindset",
    substackUrl: `${substackBase}/p/all-or-nothing-mindset`,
    gradient: "linear-gradient(135deg, #E8D5C4 0%, #C4A882 100%)",
  },
  {
    title: "3 Reasons the Scale Is Lying to You",
    excerpt:
      "Daily weigh-ins can sabotage your progress and your mental health. Learn what the scale actually measures — and which metrics matter for body recomposition.",
    category: "Fitness",
    date: "April 20, 2025",
    slug: "scale-lying",
    substackUrl: `${substackBase}/p/scale-lying`,
    gradient: "linear-gradient(135deg, #D4A5A0 0%, #5A3E36 100%)",
  },
  {
    title: "Meal Prep Made Simple: A Week of Nourishing Meals in 2 Hours",
    excerpt:
      "No complicated recipes, no exhausting Sundays. This is the exact meal prep routine I recommend to busy clients who want to eat well without overthinking it.",
    category: "Nutrition",
    date: "April 13, 2025",
    slug: "meal-prep-simple",
    substackUrl: `${substackBase}/p/meal-prep-simple`,
    gradient: "linear-gradient(135deg, #A67C6D 0%, #D4A5A0 100%)",
  },
];

const featured = posts[0];
const articles = posts.slice(1);
---

<BaseLayout
  title="Blog"
  description="Fitness, nutrition, and mindset content from Novella — practical advice for women who want lasting results."
>

  <!-- ── Featured Story Hero ─────────────────────────────────────── -->
  <section class="bg-cream py-10 px-4 md:px-8">
    <div class="max-w-6xl mx-auto">
      <div
        class="rounded-3xl overflow-hidden grid grid-cols-1 md:grid-cols-5 min-h-[380px]"
        style="background-color: #EDE4D8;"
      >
        <!-- Left: text panel -->
        <div class="md:col-span-2 flex flex-col justify-between p-8 md:p-10">
          <div>
            <p class="text-blush-dark text-xs font-bold uppercase tracking-widest mb-5">
              Featured Story
            </p>
            <h1
              class="text-3xl md:text-4xl font-bold text-brown-dark leading-tight mb-4"
              style="font-family: 'Playfair Display', serif;"
            >
              {featured.title}
            </h1>
            <p class="text-brown-dark/65 text-sm leading-relaxed mb-8">{featured.excerpt}</p>
            <a
              href={featured.substackUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-brown-dark text-cream text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-brown transition-colors"
            >
              Read Story
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
          <!-- Slide indicators -->
          <div class="flex items-center gap-4 mt-8">
            {[1, 2, 3].map((n) => (
              <span
                class={`text-sm font-semibold ${n === 1 ? "text-brown-dark border-b-2 border-brown pb-0.5" : "text-brown-dark/30"}`}
              >
                0{n}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: gradient image -->
        <div
          class="md:col-span-3 min-h-[260px] md:min-h-0 relative"
          style={`background: ${featured.gradient};`}
          aria-hidden="true"
        >
          <!-- Decorative silhouette -->
          <div class="absolute inset-0 flex items-end justify-center pb-6 opacity-20">
            <svg viewBox="0 0 200 260" width="160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="100" cy="48" rx="34" ry="38" fill="white"/>
              <path d="M65 88 Q40 118 45 180 Q56 230 100 245 Q144 230 155 180 Q160 118 135 88 Q120 74 100 76 Q80 74 65 88Z" fill="white"/>
            </svg>
          </div>
          <span class="absolute bottom-4 right-5 text-white/40 text-xs uppercase tracking-wider">
            {featured.category}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Substack Subscribe Banner ─────────────────────────────────── -->
  <section class="py-8 px-4 md:px-8">
    <div
      class="max-w-6xl mx-auto rounded-2xl px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-5"
      style="background: linear-gradient(135deg, #7C5C52 0%, #5A3E36 100%);"
    >
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-[#FF6719] flex items-center justify-center flex-shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
          </svg>
        </div>
        <div>
          <p class="text-cream font-semibold text-sm leading-snug">Get new posts in your inbox</p>
          <p class="text-cream/60 text-xs">Free weekly content — no spam, unsubscribe anytime.</p>
        </div>
      </div>
      <a
        href={substackBase}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-shrink-0 flex items-center gap-2 bg-[#FF6719] text-white font-semibold px-5 py-2.5 rounded-full hover:bg-[#e05510] transition-colors text-sm"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
        </svg>
        Subscribe on Substack
      </a>
    </div>
  </section>

  <!-- ── Category Tiles ─────────────────────────────────────────── -->
  <section class="px-4 md:px-8 pb-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="category-tiles">
        <!-- All -->
        <button
          data-category="All"
          class="category-btn active flex items-center gap-3 bg-white rounded-xl p-3 border border-blush/30 hover:border-brown transition-colors text-left"
        >
          <div
            class="w-12 h-12 rounded-lg flex-shrink-0"
            style="background: linear-gradient(135deg, #D4A5A0, #7C5C52);"
            aria-hidden="true"
          ></div>
          <div>
            <p class="text-brown-dark text-sm font-bold leading-tight">All Posts</p>
            <p class="text-brown-dark/50 text-xs leading-tight mt-0.5">Every topic, all in one</p>
          </div>
        </button>

        {Object.entries(categoryMeta).map(([cat, meta]) => (
          <button
            data-category={cat}
            class="category-btn flex items-center gap-3 bg-white rounded-xl p-3 border border-blush/30 hover:border-brown transition-colors text-left"
          >
            <div
              class="w-12 h-12 rounded-lg flex-shrink-0"
              style={`background: ${meta.gradient};`}
              aria-hidden="true"
            ></div>
            <div>
              <p class="text-brown-dark text-sm font-bold leading-tight">{cat}</p>
              <p class="text-brown-dark/50 text-xs leading-tight mt-0.5">{meta.description}</p>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Latest Articles ────────────────────────────────────────── -->
  <section class="bg-cream pt-6 pb-24 px-4 md:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-brown-dark" style="font-family: 'Playfair Display', serif;">
          Latest Articles
        </h2>
        <a
          href={substackBase}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-brown text-sm font-medium hover:text-brown-dark transition-colors"
        >
          View All on Substack
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="posts-grid">
        {articles.map((post) => (
          <div data-category={post.category}>
            <BlogCard
              title={post.title}
              excerpt={post.excerpt}
              category={post.category}
              categoryColor={categoryMeta[post.category]?.color ?? "#7C5C52"}
              date={post.date}
              slug={post.slug}
              substackUrl={post.substackUrl}
              gradient={post.gradient}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ─────────────────────────────────────────────── -->
  <section class="bg-brown-dark py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-cream mb-4">Want results that last?</h2>
      <p class="text-cream/70 mb-10 text-lg">
        Reading is a great start. Working together is where the real transformation happens.
      </p>
      <Button href="/contact">Book a Free Discovery Call</Button>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".category-btn");
  const cards = document.querySelectorAll<HTMLElement>("#posts-grid [data-category]");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const selected = btn.dataset.category ?? "All";

      buttons.forEach((b) => {
        const isActive = b.dataset.category === selected;
        b.classList.toggle("active", isActive);
        b.classList.toggle("border-brown", isActive);
        b.classList.toggle("border-blush/30", !isActive);
      });

      cards.forEach((card) => {
        const show = selected === "All" || card.dataset.category === selected;
        card.style.display = show ? "" : "none";
      });
    });
  });
</script>

<style>
  .category-btn.active {
    border-color: #7C5C52;
    background-color: #F5EFE6;
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import BlogCard from "../components/BlogCard.astro";

const testimonials = [
  {
    name: "Mia R.",
    result: "Lost 18 lbs & gained visible muscle in 12 weeks",
    quote:
      "I had tried every diet out there and always ended up back at square one. Novella completely changed how I think about food and training. I finally feel strong and confident in my body.",
  },
  {
    name: "Jordan T.",
    result: "Dropped 2 dress sizes, maintained for 8+ months",
    quote:
      "The weekly check-ins kept me accountable without feeling judged. Novella's approach is rooted in science but feels so personal. I wasn't just another client — she genuinely cares.",
  },
  {
    name: "Priya K.",
    result: "Broke through a 6-month plateau, rebuilt her relationship with food",
    quote:
      "As someone dealing with hormonal imbalances, I struggled for years. Novella understood exactly what I needed. My energy, sleep, and confidence are completely transformed.",
  },
];

const benefits = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2l1.5 1.5"/><path d="M9 4a5 5 0 0 1 5 5c0 1.5-.5 2.8-1.3 3.8L18 19a1 1 0 0 1-1.4 1.4l-5.3-5.3A5 5 0 1 1 9 4z"/><path d="M6 9h6"/></svg>`,
    headline: "Personalized Nutrition",
    body: "No cookie-cutter meal plans. Your nutrition strategy is built around your hormones, lifestyle, and food preferences — so it actually works for you long-term.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" y1="20" x2="20" y2="20"/></svg>`,
    headline: "Strength-Based Training",
    body: "Build muscle, boost metabolism, and feel powerful. Programs designed to make you stronger — not just smaller — with workouts you can do at the gym or at home.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    headline: "Weekly 1:1 Coaching",
    body: "Real support from a real human. Weekly check-ins, unlimited messaging, and progress reviews keep you on track and feeling supported every step of the way.",
  },
];

const steps = [
  {
    number: "01",
    title: "Apply",
    description:
      "Fill out a short application so we can understand your goals, history, and what makes you tick.",
  },
  {
    number: "02",
    title: "Get Your Custom Plan",
    description:
      "Receive a fully personalized workout and nutrition plan built specifically for your body and lifestyle.",
  },
  {
    number: "03",
    title: "Transform & Thrive",
    description:
      "Execute with confidence, adjust in real time with Novella's guidance, and watch your results compound.",
  },
];
---

<BaseLayout
  title="Home"
  description="Novella — Online fitness coaching for women. Transform your body, reclaim your confidence."
>
  <!-- Hero -->
  <section class="bg-cream min-h-[calc(100vh-72px)] flex items-center py-20">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-blush-dark text-sm font-semibold uppercase tracking-widest mb-4">
          Women's Fitness Coaching
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brown-dark leading-tight mb-6">
          Transform Your Body.<br />
          <span class="text-brown">Reclaim Your Confidence.</span>
        </h1>
        <p class="text-brown-dark/70 text-lg leading-relaxed mb-8 max-w-md">
          Online fitness &amp; nutrition coaching designed for women who want lasting results — without
          restriction, burnout, or giving up what they love.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/contact">Book a Free Discovery Call</Button>
          <Button href="/programs" variant="secondary">View Programs</Button>
        </div>
      </div>

      <!-- Placeholder image -->
      <div class="relative flex justify-center">
        <div
          class="w-full max-w-sm aspect-[3/4] rounded-3xl shadow-xl overflow-hidden"
          style="background: linear-gradient(145deg, #D4A5A0 0%, #A67C6D 40%, #7C5C52 100%);"
          aria-hidden="true"
        >
          <div class="absolute inset-0 flex items-end justify-center pb-10">
            <svg
              viewBox="0 0 160 220"
              width="160"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <ellipse cx="80" cy="40" rx="28" ry="32" fill="#F5EFE6" opacity="0.25"></ellipse>
              <path
                d="M52 70 Q30 100 35 160 Q45 200 80 210 Q115 200 125 160 Q130 100 108 70 Q95 60 80 62 Q65 60 52 70Z"
                fill="#F5EFE6"
                opacity="0.2"></path>
              <path
                d="M52 72 Q20 85 18 140"
                stroke="#F5EFE6"
                stroke-width="18"
                stroke-linecap="round"
                opacity="0.18"></path>
              <path
                d="M108 72 Q140 85 142 140"
                stroke="#F5EFE6"
                stroke-width="18"
                stroke-linecap="round"
                opacity="0.18"></path>
            </svg>
          </div>
          <div class="absolute bottom-8 left-0 right-0 text-center">
            <p class="text-cream/60 text-xs tracking-wider uppercase">Your transformation starts here</p>
          </div>
        </div>
        <!-- Floating stat badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg px-5 py-3">
          <p class="text-2xl font-bold text-brown">200+</p>
          <p class="text-xs text-brown-light">Women Transformed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section class="bg-brown py-12">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div>
          <p class="text-4xl font-bold text-cream mb-1">200+</p>
          <p class="text-cream/70 text-sm">Women Transformed</p>
        </div>
        <div class="sm:border-x sm:border-cream/20">
          <p class="text-4xl font-bold text-cream mb-1">5-Star</p>
          <p class="text-cream/70 text-sm">Average Rating</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-cream mb-1">12-Week</p>
          <p class="text-cream/70 text-sm">Programs</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-cream py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-blush-dark text-sm font-semibold uppercase tracking-widest mb-3">What You Get</p>
        <h2 class="text-3xl md:text-4xl font-bold text-brown-dark">Everything You Need to Succeed</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          benefits.map((benefit) => (
            <div class="bg-white rounded-2xl shadow-md p-8 hover:-translate-y-1 transition-transform duration-300">
              <div class="text-blush mb-5" set:html={benefit.icon} />
              <h3 class="text-xl font-bold text-brown-dark mb-3">{benefit.headline}</h3>
              <p class="text-brown-dark/70 text-sm leading-relaxed">{benefit.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24" style="background-color: color-mix(in srgb, #D4A5A0 10%, #F5EFE6);">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-blush-dark text-sm font-semibold uppercase tracking-widest mb-3">The Process</p>
        <h2 class="text-3xl md:text-4xl font-bold text-brown-dark">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <!-- Connector line (desktop only) -->
        <div
          class="hidden md:block absolute top-10 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-0.5"
          style="background-color: #D4A5A080;"
          aria-hidden="true"
        >
        </div>
        {
          steps.map((step) => (
            <div class="flex flex-col items-center text-center relative">
              <div class="w-20 h-20 rounded-full bg-brown text-cream flex items-center justify-center text-2xl font-bold mb-6 shadow-md z-10">
                {step.number}
              </div>
              <h3 class="text-xl font-bold text-brown-dark mb-3">{step.title}</h3>
              <p class="text-brown-dark/70 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-cream py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-blush-dark text-sm font-semibold uppercase tracking-widest mb-3">Client Love</p>
        <h2 class="text-3xl md:text-4xl font-bold text-brown-dark">Real Women, Real Results</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((t) => <TestimonialCard name={t.name} result={t.result} quote={t.quote} />)}
      </div>
    </div>
  </section>

  <!-- From the Blog -->
  <section class="bg-cream py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
        <div>
          <p class="text-blush-dark text-sm font-semibold uppercase tracking-widest mb-3">From the Blog</p>
          <h2 class="text-3xl md:text-4xl font-bold text-brown-dark">Real Talk on Fitness &amp; Nutrition</h2>
        </div>
        <a href="/blog" class="text-brown font-medium text-sm hover:text-brown-dark transition-colors whitespace-nowrap">
          View all posts →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <BlogCard
          title="5 Signs Your Hormones Are Affecting Your Weight Loss"
          excerpt="Struggling to lose weight despite doing everything 'right'? Your hormones might be working against you. Here's how to spot the signs — and what to do about them."
          category="Nutrition"
          date="May 18, 2025"
          slug="hormones-weight-loss"
          substackUrl="https://novella.substack.com/p/hormones-weight-loss"
          gradient="linear-gradient(135deg, #D4A5A0 0%, #A67C6D 100%)"
        />
        <BlogCard
          title="The Strength Training Guide for Women Who've Never Lifted"
          excerpt="Intimidated by the weight room? You shouldn't be. This beginner-friendly guide breaks down exactly where to start — no experience required."
          category="Fitness"
          date="May 11, 2025"
          slug="strength-training-beginners"
          substackUrl="https://novella.substack.com/p/strength-training-beginners"
          gradient="linear-gradient(135deg, #B07870 0%, #7C5C52 100%)"
        />
        <BlogCard
          title="What to Eat Before and After Your Workout"
          excerpt="Fueling your training correctly can mean the difference between a great session and running on empty. Here's the simple framework I give every client."
          category="Nutrition"
          date="May 4, 2025"
          slug="pre-post-workout-nutrition"
          substackUrl="https://novella.substack.com/p/pre-post-workout-nutrition"
          gradient="linear-gradient(135deg, #C4A882 0%, #A67C6D 100%)"
        />
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-brown-dark py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-cream mb-4">Ready to Start Your Journey?</h2>
      <p class="text-cream/70 mb-10 text-lg">
        Let's talk about your goals, your challenges, and how we can build a plan that actually works for
        your life.
      </p>
      <Button href="/contact">Book a Free Discovery Call</Button>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Contact"
  description="Book a free discovery call with Novella or send a message. Let's talk about your fitness goals."
>
  <!-- Page Hero -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-blush-dark text-sm font-semibold uppercase tracking-widest mb-3">Get In Touch</p>
      <h1 class="text-4xl md:text-5xl font-bold text-brown-dark mb-4">Let's Connect</h1>
      <p class="text-brown-dark/70 text-lg max-w-xl mx-auto">
        Have questions or ready to get started? Reach out — Novella responds within 24 hours.
      </p>
    </div>
  </section>

  <!-- Two-column contact section -->
  <section class="bg-cream pb-24">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <!-- Left: Contact info + Calendly -->
      <div>
        <h2 class="text-2xl font-bold text-brown-dark mb-8">Reach Out</h2>

        <div class="flex flex-col gap-6 mb-12">
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blush/20 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#B07870"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-brown-dark mb-0.5">Email</p>
              <a href="mailto:hello@novellafit.com" class="text-blush-dark hover:text-brown transition-colors text-sm">
                hello@novellafit.com
              </a>
            </div>
          </div>

          <!-- Instagram -->
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blush/20 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#B07870"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.5" cy="6.5" r="0.5" fill="#B07870" stroke="none"></circle>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-brown-dark mb-0.5">Instagram</p>
              <a href="https://instagram.com/novellafit" class="text-blush-dark hover:text-brown transition-colors text-sm">
                @novellafit
              </a>
            </div>
          </div>

          <!-- Free Call -->
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blush/20 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#B07870"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.92 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-brown-dark mb-0.5">Free Discovery Call</p>
              <p class="text-brown-dark/60 text-sm">30 minutes · No commitment · Book below</p>
            </div>
          </div>
        </div>

        <!-- Calendly placeholder -->
        <div
          class="bg-white rounded-2xl shadow-md p-8 border-2 border-dashed border-blush/40 text-center"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#D4A5A0"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mx-auto mb-4"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <h3 class="text-lg font-bold text-brown-dark mb-2">Book Directly on Calendly</h3>
          <p class="text-brown-dark/60 text-sm mb-6">
            Pick a time that works for you. The call is free and takes about 30 minutes.
          </p>
          <a
            href="https://calendly.com/novellafit"
            class="inline-flex items-center justify-center px-6 py-3 bg-brown text-cream rounded-full text-sm font-medium hover:bg-brown-dark transition-colors"
          >
            View Available Times
          </a>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div>
        <h2 class="text-2xl font-bold text-brown-dark mb-8">Send a Message</h2>
        <form
          id="contact-form"
          class="flex flex-col gap-5"
          novalidate
        >
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-medium text-brown-dark mb-1.5">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full px-4 py-3 rounded-xl border border-blush/40 bg-white text-brown-dark placeholder:text-brown-dark/30 focus:outline-none focus:ring-2 focus:ring-blush text-sm"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-medium text-brown-dark mb-1.5">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@example.com"
              class="w-full px-4 py-3 rounded-xl border border-blush/40 bg-white text-brown-dark placeholder:text-brown-dark/30 focus:outline-none focus:ring-2 focus:ring-blush text-sm"
            />
          </div>

          <!-- How did you hear -->
          <div>
            <label for="source" class="block text-sm font-medium text-brown-dark mb-1.5">
              How did you hear about Novella?
            </label>
            <select
              id="source"
              name="source"
              class="w-full px-4 py-3 rounded-xl border border-blush/40 bg-white text-brown-dark focus:outline-none focus:ring-2 focus:ring-blush text-sm appearance-none"
            >
              <option value="">Select an option</option>
              <option value="instagram">Instagram</option>
              <option value="tiktok">TikTok</option>
              <option value="google">Google Search</option>
              <option value="friend">Friend or Family</option>
              <option value="podcast">Podcast</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-medium text-brown-dark mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell me a bit about your goals and what you're looking for..."
              class="w-full px-4 py-3 rounded-xl border border-blush/40 bg-white text-brown-dark placeholder:text-brown-dark/30 focus:outline-none focus:ring-2 focus:ring-blush text-sm resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="inline-flex items-center justify-center px-7 py-3.5 bg-brown text-cream rounded-full font-medium text-sm hover:bg-brown-dark transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brown"
          >
            Send Message
          </button>
        </form>

        <!-- Success state (hidden by default) -->
        <div
          id="form-success"
          class="hidden bg-blush/10 border border-blush/30 rounded-2xl p-8 text-center mt-4"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#D4A5A0"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mx-auto mb-4"
          >
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <h3 class="text-xl font-bold text-brown-dark mb-2">Message Received!</h3>
          <p class="text-brown-dark/70 text-sm">
            We'll be in touch within 24 hours. Looking forward to connecting!
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const successMsg = document.getElementById("form-success");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.classList.add("hidden");
    successMsg?.classList.remove("hidden");
  });
</script>

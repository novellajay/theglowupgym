---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/programs", label: "Programs" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="bg-brown-dark text-cream">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand column -->
      <div>
        <p class="text-2xl font-bold mb-3" style="font-family: 'Playfair Display', serif;">Novella</p>
        <p class="text-cream/70 text-sm leading-relaxed">Empowering women through fitness.</p>
      </div>

      <!-- Navigation column -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-cream/50 mb-4">Navigation</p>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-cream/80 hover:text-cream transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social column -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-cream/50 mb-4">Follow Along</p>
        <div class="flex gap-4">
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="text-cream/70 hover:text-cream transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="text-cream/70 hover:text-cream transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <!-- TikTok -->
          <a href="#" aria-label="TikTok" class="text-cream/70 hover:text-cream transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-cream/10 mt-12 pt-8 text-center">
      <p class="text-cream/50 text-sm">&copy; 2025 Novella. All rights reserved.</p>
    </div>
  </div>
</footer>
